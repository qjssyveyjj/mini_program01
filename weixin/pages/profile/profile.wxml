<view class="container">
  <view class="profile-header card">
    <image class="avatar" src="{{userInfo.avatar || '/static/avatar.png'}}" mode="aspectFill" />
    <view class="info">
      <text class="nickname">{{userInfo.nickname || '微信用户'}}</text>
      <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
    </view>
  </view>

  <view class="card menu">
    <view class="menu-item" bindtap="goLog">
      <text>记录健康数据</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goChat">
      <text>AI 健康客服</text>
      <text class="arrow">></text>
    </view>
  </view>

  <button class="btn-accent relogin-btn" bindtap="relogin">重新登录</button>
</view>
