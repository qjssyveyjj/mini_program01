.header {
  background: linear-gradient(135deg, #42A5F5, #66BB6A);
  color: #fff;
}
.greeting {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
}
.sub {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: 0.9;
}
.card-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}
.metrics {
  display: flex;
  flex-wrap: wrap;
}
.metric {
  width: 50%;
  text-align: center;
  margin-bottom: 24rpx;
}
.metric-value {
  display: block;
  font-size: 40rpx;
  color: #42A5F5;
  font-weight: bold;
}
.metric-label {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}
.time {
  font-size: 24rpx;
  color: #aaa;
}
.empty {
  color: #aaa;
  text-align: center;
  padding: 40rpx 0;
}
.log-btn {
  margin-top: 24rpx;
  border-radius: 48rpx;
}
