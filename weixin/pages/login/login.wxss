.login-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 48rpx 120rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #42A5F5, #66BB6A);
}
.brand {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.brand-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
}
.brand-sub {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}
.login-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.login-btn {
  width: 100%;
  border-radius: 48rpx;
  background-color: #fff;
  color: #42A5F5;
}
.tip {
  margin-top: 24rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}
