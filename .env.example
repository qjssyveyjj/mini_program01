# docker-compose 环境变量模板：复制为 .env 并填入真实值
# 用法：cp .env.example .env  然后  docker compose up -d --build

# 外部 MySQL 连接（不在 Docker 中部署数据库）
# Docker 容器访问宿主机上的 MySQL：DB_HOST=host.docker.internal
# 访问远程云数据库：DB_HOST=你的数据库IP或域名
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=health_manager
DB_USERNAME=root
DB_PASSWORD=your_db_password

# 阿里云百炼（DashScope）OpenAI 兼容接口
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
OPENAI_API_KEY=your_dashscope_api_key

# 微信小程序
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 前端构建期 API 基础地址（经 nginx 反代到后端，通常保持 /api）
VITE_API_BASE_URL=/api
