# docker-compose 环境变量模板：复制为 .env 并填入真实值（.env 不提交到 git）
# 用法：cp .env.example .env  然后  docker compose up -d --build

# 数据库密码（同时作为 MySQL root 密码与后端连接密码）
DB_PASSWORD=your_db_password

# 阿里云百炼（DashScope）OpenAI 兼容接口
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
OPENAI_API_KEY=your_dashscope_api_key

# 微信小程序
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 前端构建期 API 基础地址（经 nginx 反代到后端，通常保持 /api）
VITE_API_BASE_URL=/api
