# 项目环境变量（复制为 .env 并修改，docker-compose 与本地后端共用）
# 用法：cp .env.example .env

# ===== 数据库（仅需 3 项）=====
SPRING_DATASOURCE_URL=jdbc:mysql://172.22.67.85:3306/health_manager?characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
# 密码含 # 等特殊字符时必须加双引号
SPRING_DATASOURCE_PASSWORD="your_db_password"

# ===== 阿里云百炼 =====
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=your_dashscope_api_key

# ===== 微信小程序 =====
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# ===== 前端构建 =====
VITE_API_BASE_URL=/api
